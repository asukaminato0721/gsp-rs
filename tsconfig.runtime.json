    "src/html/runtime/viewer_render_polygons.ts",
    "src/html/runtime/viewer_render_circular.ts",
    "src/html/runtime/viewer_render_labels.ts",
    "src/html/runtime/viewer_render_tables.ts",
    "src/html/runtime/viewer_render_hotspots.ts",
    "src/html/runtime/viewer_overlay.ts",
