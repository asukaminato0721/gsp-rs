{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "lib": ["ES2021", "DOM"],
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitReturns": true,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true
  },
  "include": [
    "src/html/runtime/**/*.ts",
    "src/html/generated/**/*.ts",
    "src/html/viewer_types.d.ts",
    "src/html/vendor/van-1.6.0.d.ts"
  ]
}
